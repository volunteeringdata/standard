# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Taxonomy top concept
:Cause
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:topConceptOf :Taxonomy ;
    skos:prefLabel "Cause"@en ;
    skos:definition "Any charitable cause related to volunteering activities."@en ;
.


## Cause Concepts
:AnimalWelfare
    a skos:Concept ;
    skos:prefLabel "Animal Welfare"@en ;
    skos:altLabel "Wildlife"@en, "Pets"@en, "Creatures"@en, "Mammals"@en ;
    skos:definition "Volunteering focused on the protection, care, and welfare of animals, including wildlife conservation, pet support, and creature advocacy."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:AntiPoverty
    a skos:Concept ;
    skos:prefLabel "Anti-Poverty"@en ;
    skos:altLabel "Poverty Reduction"@en, "Tackling Poverty"@en ;
    skos:definition "Volunteering activities aimed at reducing poverty, supporting low-income households, and promoting economic empowerment."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:ArtsAndCulture
    a skos:Concept ;
    skos:prefLabel "Arts and Culture"@en ;
    skos:altLabel "Culture"@en, "Society"@en, "Humanities"@en, "Music"@en, "Theatre"@en, "Dance"@en, "Graphic Arts"@en, "Crafts"@en ;
    skos:definition "Volunteering in artistic and cultural domains including music, theatre, dance, visual arts, crafts, and heritage preservation."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Care
    a skos:Concept ;
    skos:prefLabel "Care"@en ;
    skos:altLabel "Care Services"@en, "Care Providers"@en, "Counselling Support"@en, "Addiction Support"@en, "Social Care"@en, "Carers"@en, "Caregivers"@en, "Guardians"@en, "Live in carers"@en, "Home Carers"@en ;
    skos:definition "Volunteering providing care services, support to carers, counselling, and social care assistance."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:CivilRights
    a skos:Concept ;
    skos:prefLabel "Civil Rights"@en ;
    skos:altLabel "Human Rights"@en, "Citizens Rights"@en, "Equality"@en, "Justice"@en ;
    skos:definition "Volunteering promoting human rights, civil liberties, equality, justice, and citizen empowerment."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:Community
    a skos:Concept ;
    skos:prefLabel "Community"@en ;
    skos:altLabel "Community groups"@en, "Society"@en, "Local Public"@en ;
    skos:definition "Volunteering supporting community development, local initiatives, and strengthening of community groups."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

:CrimeSafety
    a skos:Concept ;
    skos:prefLabel "Crime / Safety"@en ;
    skos:altLabel "Protection"@en, "Security"@en, "Offences"@en, "Wrongdoing"@en ;
    skos:definition "Volunteering supporting crime prevention, public safety, victim support, and protection services."@en ;
    skos:broader :Cause ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

