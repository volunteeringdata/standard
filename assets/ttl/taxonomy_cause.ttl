    skos:altLabel "Criminal Justice System"@en, "Prisons"@en ;
    skos:definition "Volunteering supporting offenders, ex-offenders, rehabilitation programmes, and the criminal justice system."@en ;
    skos:broader :CrimeSafety ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
.

