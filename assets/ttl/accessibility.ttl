# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://ns.volunteeringdata.io/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


## Taxonomy top concept
:Accessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:topConceptOf :Taxonomy ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Accessibility"@en ;
    skos:definition "Any accessibility information related to volunteering activities."@en ;
.


### Taxonomy Hierarchy
:AgeRequirements
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Age Requirements" ;
    skos:definition "Any information regarding specific ages or ranges of ages required or disallowed from a activity." ;
.

:DigitalAccessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Digital Accessibility"@en ;
    skos:definition "Any accessbility information regarding digital requirements for an activity"@en ;
.

:ExpensesPaid
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Expenses Paid" ;
    skos:definition "Any information regarding reimbursement for activity or role-related expenses.";
.

:LanguageRequirements
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Language Requirements" ;
    skos:definition "Any language information for an activity, including required language(s) and translation services available." ;
.

:PhysicalAccessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :Taxonomy ;
    skos:prefLabel "Physical Accessibility"@en ;
    skos:definition "Any accessbibility information regarding physical ability required for an activity" ;
.


##Digital Accessibility Concepts
:WifiUsage
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :DigitalAccessibility ;
    skos:prefLabel "Wifi Usage" ;
    skos:definition "Any information on wifi usage necessary for a activity." ;
.

:TechnologyRequirements
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :DigitalAccessibility ;
    skos:prefLabel "Technology Requirements" ;
    skos:definition "Any information on devices (laptop, phone, smartphone) and software required for a activity." ;
.

:TechnologyAvailability
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :DigitalAccessibility ;
    skos:prefLabel "Technology Availability" ;
    skos:definition "Any information on supplementory accessiblity software available in activities (screen readers, captioning)." ;
.


##Physical Accessibility Concepts
:RemoteAccessibility
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Remote Accessibility" ;
    skos:definition "Any accomodations available for remote participation in an activity." ;
.

:BuildingAccessibilityFeatures
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Building Accessibility Features" ;
    skos:definition "Any information on building accessibility features for mobility aid users and accessible gender, faith, etc. rooms." ;
.

:PublicTransportAccess
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Public Transport Access" ;
    skos:definition "Any information on venue access via public transport lines." ;
.

:ParkingAvailability
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Parking Availability" ;
    skos:definition "Any information on parking availability and accessibility at the venue." ;
.

:ServiceAnimals
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Service Animals" ;
    skos:definition "Accessiblity information regarding usage of service animals in and around venue." ;
.

:VisualImpairment
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Visual Impairment" ;
    skos:definition "Any information on activities wherin visual impairments may be affected or accommodated." ;
.

:CareProfessionals
    a skos:Concept ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    skos:broader :Accessibility ;
    skos:inScheme :PhysicalAccessibility ;
    skos:prefLabel "Care Professionals" ;
    skos:definition "Any accommodations available for volunteers assisted by care professionals." ;
.
