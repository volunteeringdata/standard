### Concept Object Properties
:concept
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:range :Concept ;
    rdfs:label "has concept"@en .

:accessibility
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    rdfs:range :Accessibility ;
    rdfs:label "has accessibility information"@en .

:demography
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    rdfs:range :Demography ;
    rdfs:label "has demographic target"@en .

:language
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    rdfs:range :Language ;
    rdfs:label "has language"@en .

:requirement
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    rdfs:range :Requirement ;
    rdfs:label "has requirement"@en .

:reward
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    rdfs:range :Reward ;
    rdfs:label "has reward"@en .

:skill
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    rdfs:range :Skill ;
    rdfs:label "has skill"@en .


### Concept Classification Object Properties
:activityConcept
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :concept ;
    owl:inverseOf :conceptActivity ;
    rdfs:domain :Activity ;
    rdfs:range :ActivityConcept ;
    rdfs:label "activity has concept"@en .

:activityAccessibility
    a owl:ObjectProperty ;
    rdfs:isDefinedBy <https://ns.volunteeringdata.io/> ;
    rdfs:subPropertyOf :activityConcept, :accessibility ;
    owl:inverseOf :accessibilityActivity ;
