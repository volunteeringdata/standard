# Volunteering vocabulary

## Namespaces
### Ontology Base URI
prefix :                <https://id.volunteeringdata.io/schema/>

### Core W3C ontologies (OWL 2 reserved vocabulary)
prefix rdf:             <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs:            <http://www.w3.org/2000/01/rdf-schema#>
prefix owl:             <http://www.w3.org/2002/07/owl#>
prefix xsd:             <http://www.w3.org/2001/XMLSchema#>

### Other namespaces used
prefix dc:              <http://purl.org/dc/terms/>
prefix skos:            <http://www.w3.org/2004/02/skos/core#>
prefix time:            <http://www.w3.org/2006/time#>
prefix vcard:           <http://www.w3.org/2006/vcard/ns#>
prefix vann:            <http://purl.org/vocab/vann/>


# Class
:Time rdfs:subClassOf time:TemporalEntity .

# Properties
:beginning
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy id:schema ;
    rdfs:subPropertyOf time:hasBeginning ;
    rdfs:domain :Time ;
    rdfs:label "has beginning"@en ;
.

:end
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy id:schema ;
    rdfs:subPropertyOf time:hasEnd ;
    rdfs:domain :Time ;
    rdfs:label "has end"@en ;
.

# Defined Temporal Entities
:MondayMorning
    a time:TemporalEntity, :WeekDayTimePeriod ;
    time:hasBeginning [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "6"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
    time:hasEnd [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "12"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
.

