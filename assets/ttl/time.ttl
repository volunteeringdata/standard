@prefix time: <http://www.w3.org> .
@prefix xsd: <http://www.w3.org> .


:MorningBeginning
    a time:Instant ;
    time:inTimePosition [
        time:nominalPosition "06:00:00"^^xsd:time ;
        time:hasTRS <http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> ;
    ] ;
.

:AfternoonBeginning
    a time:Instant ;
    time:inTimePosition [
        time:nominalPosition "12:00:00"^^xsd:time ;
        time:hasTRS <http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> ;
    ] ;
.

:EveningBeginning
    a time:Instant ;
    time:inTimePosition [
        time:nominalPosition "18:00:00"^^xsd:time ;
        time:hasTRS <http://www.opengis.net/def/uom/ISO-8601/0/Gregorian> ;
    ] ;
.

:MondayMorning
    a time:DateTimeInterval ;
    time:hasBeginning :MorningBeginning ;
    time:hasEnd :AfternoonBeginning ;
    time:hasDateTimeDescription [
        a time:GeneralDateTimeDescription ;
        time:dayOfWeek :Monday ;
    ] ;
.

:MondayMorning
    a time:ProperInterval ;
    time:hasBeginning [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "6"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
    time:hasEnd [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "12"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
.



:MondayMorning
    a time:TemporalEntity, :WeekDayTimePeriod ;
    time:hasBeginning [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "6"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
    time:hasEnd [
        a time:Instant ;
        time:inDateTime [
            a time:GeneralDateTimeDescription ;
            time:dayOfWeek time:Monday ;
            time:hour "12"^^xsd:nonNegativeInteger ;
            time:minute "0"^^xsd:nonNegativeInteger ;
            time:second "0"^^xsd:nonNegativeInteger ;
        ] ;
    ] ;
.
